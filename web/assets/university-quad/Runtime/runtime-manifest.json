{
  "schemaVersion": 1,
  "packageId": "safety-school-university-quad-v1",
  "target": "browser-canvas-or-dom",
  "coordinateSpace": {
    "width": 1536,
    "height": 1024,
    "origin": "top-left",
    "xAxis": "right",
    "yAxis": "down",
    "units": "source-pixels"
  },
  "board": {
    "image": "Board/quad-base-six-pad.png",
    "size": [1536, 1024],
    "alphaBounds": [53, 96, 1425, 875],
    "fit": "contain",
    "sampling": "linear",
    "transform": {
      "scale": "min(stageWidth / 1536, stageHeight / 1024)",
      "offsetX": "stageX + (stageWidth - 1536 * scale) / 2",
      "offsetY": "stageY + (stageHeight - 1024 * scale) / 2",
      "screenX": "offsetX + boardX * scale",
      "screenY": "offsetY + boardY * scale"
    }
  },
  "viewportContract": {
    "pageScroll": false,
    "headerHeight": 68,
    "bottomHudHeight": 86,
    "activityRailWidth": { "default": 246, "compact": 208 },
    "fixtures": [
      { "viewport": [1280, 720], "stageRect": [0, 68, 1034, 566], "boardRenderRect": [92, 68, 849, 566] },
      { "viewport": [1024, 768], "stageRect": [0, 68, 816, 614], "boardRenderRect": [0, 103, 816, 544] }
    ]
  },
