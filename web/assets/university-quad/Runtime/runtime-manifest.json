  "buildingTemplate": {
    "images": {
      "academics": "Buildings/academics.png",
      "student-affairs": "Buildings/student-affairs.png",
      "athletics": "Buildings/athletics.png",
      "admissions": "Buildings/admissions.png",
      "marketing": "Buildings/marketing.png",
      "administration": "Buildings/administration.png"
    },
    "size": [512, 512],
    "sourcePivot": [256, 480],
    "placement": "sourcePivot-to-pad-placementPivot",
    "contactShadowOwner": "runtime",
    "contactShadow": "drop-shadow(0 8px 4px rgb(27 48 36 / 34%))",
    "levelPadCoverage": { "1": 0.75, "2": 0.8, "3": 0.85, "4": 0.9, "5": 0.95 }
  },
  "fountain": {
    "statefulImplementation": "static-sprite",
    "staticFallbackImage": "Props/central-fountain-static.png",
    "staticFallbackSize": [1254, 1254],
    "staticFallbackAlphaBounds": [225, 184, 798, 800],
    "staticFallbackPivot": [624, 984],
    "boardPivot": [768, 531],
    "staticFallbackDisplayWidth": 220,
    "waterAndJetBakedIntoFallback": true,
    "overlayProceduralWaterOnFallback": false
  },
  "characters": {
    "manifest": "Characters/student-actions.json",
    "canonicalPayload": "atlas",
    "contactShadowOwner": "runtime",
    "depthAnchor": "frame.pivot"
  },
  "depth": {
    "board": 0,
    "fountain": 20000,
    "worldObject": "30000 + round(boardPivotY)",
    "constructionFx": 50000,
    "interactionOverlay": 60000,
    "hud": 100000,
    "tieBreak": "department id or actor id, ascending"
  },
  "interactions": {
    "default": { "modelTransform": "translateX(-50%)" },
    "hover": { "pointer": "fine", "modelTransform": "translateX(-50%) translateY(-3px)", "durationMs": 150, "easing": "cubic-bezier(.22, 1, .36, 1)" },
    "focus": { "outline": "3px solid #ffd77a", "outlineOffset": 2 },
    "selected": { "captionBorder": "#f0c55f", "captionRing": "0 0 0 2px rgb(240 197 95 / 38%)" },
    "pressed": { "modelTransform": "translateX(-50%) scale(.97)" },
    "validPlacement": { "outline": "3px solid #4f8a68", "previewOpacity": 0.72 },
    "invalidPlacement": { "outline": "3px solid #a55a38", "previewOpacity": 0.46 },
    "reducedMotion": { "transitions": false, "constructionDust": false, "constructionRise": false }
  },
  "construction": {
    "preview": { "asset": "target building image", "opacity": 0.55, "pointerEvents": "none" },
    "rise": { "durationMs": 760, "easing": "cubic-bezier(.23, 1, .32, 1)", "from": "translateY(58%) scale(.96)", "to": "translateY(0) scale(1)" },
    "dust": { "owner": "runtime-css", "durationMs": 820, "disabledForReducedMotion": true },
    "completion": { "retainSelectedState": true, "announceVia": "aria-live" }
  },
  "campusStates": {
    "prosperity": { "grass": "#7eaa70", "grassDark": "#56845a", "population": "high", "frisbee": true, "fountainJetScale": 1.0, "buildingSaturation": 1.0 },
    "strain": { "grass": "#7c8d68", "grassDark": "#5f6d50", "population": 6, "frisbee": false, "fountainJetScale": 0.5, "maintenanceCue": true, "buildingSaturation": 0.85 },
    "austerity": { "grass": "#797b5f", "grassDark": "#595d49", "population": 3, "frisbee": false, "fountainJetScale": 0.0, "maintenanceCue": true, "protestCue": true, "buildingSaturation": 0.65 }
  },
  "textureContract": {
    "format": "PNG",
    "colorSpace": "sRGB",
    "alpha": "straight",
    "atlasSampling": "linear",
    "atlasSafeGutter": 16,
    "mipmaps": false,
    "initialDecodedBytesMax": 29360128,
    "singleTextureDecodedBytesMax": 8388608
  }
}
